# SENTINEL-Q Environment Configuration
# Copy this file to .env and fill in values

# Flask debug mode (0=off, 1=on). NEVER enable in production.
FLASK_DEBUG=0

# Flask secret key (generate a random one for production)
# FLASK_SECRET_KEY=your-secret-key-here

# Server port
PORT=5000

# Google OAuth (optional - for Google login)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/callback/google

# Microsoft OAuth (optional - for Microsoft login)
# Get from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_REDIRECT_URI=http://localhost:5000/api/auth/callback/microsoft
